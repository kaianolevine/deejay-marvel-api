# Required
DATABASE_URL=postgresql://postgres:password@localhost:5432/deejay_sets

# Optional
ENVIRONMENT=development
API_VERSION=1.0
OWNER_ID=dev-owner
SENTRY_DSN=
CORS_ORIGINS=["*"]

# Required for the one-time historical migration script.
# GOOGLE_CREDENTIALS_JSON should be the *raw service-account JSON content* as a single-line value.
# Do NOT paste pretty-printed/multiline JSON here (python-dotenv can't parse it reliably).
# Example (bash):
#   export GOOGLE_CREDENTIALS_JSON="$(cat /path/to/service-account.json)"
GOOGLE_CREDENTIALS_JSON=

# Alternative to embedding multiline JSON:
# Put the service account JSON into a file and set its path.
GOOGLE_CREDENTIALS_JSON_PATH=

